\layout {
  \context { \Voice
	\remove Finger_glide_engraver
  }
  \context { \Score
    \override MetronomeMark.padding   = #6
    \override MetronomeMark.font-size = #-3
  }
  \context { \Staff
    \override StaffSymbol.thickness   = #0.5
    \override TimeSignature.style     = #'numbered
    \consists Merge_rests_engraver
	\consists Finger_glide_engraver

    \override Fingering.font-name        = #"Garamond"
    \override StrokeFinger.font-name     = #"Clear Sans Italic"
    \override StrokeFinger.font-size     = #-4
	\override StrokeFinger.padding       = #0.5     % 0.5 is the default, adjust if necessary
    \override Fingering.add-stem-support = #only-if-beamed
    \override StrokeFinger.avoid-slur    = #'inside
    % the above is to avoid a warning, not even sure what it does
  }
  \context { \StaffGroup
    \consists "Instrument_name_engraver"
  }
}

voiceOne = \new Voice {
  \voiceOne
  \set fingeringOrientations    = #'(left)
  \set strokeFingerOrientations = #'(up)
  \set fontSize = #-1   % make note heads smaller

  % StrokeFinger.staff-padding
  %  . defaults work well but tweaks may be necessary with multiple voices
  %  . uncomment and adjust as necessary, here and/or in other voices
  %\override StrokeFinger.staff-padding = #3.5

  % other useful idioms:
  % \once \override NoteColumn.force-hshift = 0.25 <insert_note_here>

  \relative c'' {
    \slurDown <b \RH #3 >16 <a \RH #2 > <gis \RH #3 > (a) r a <cis-3> e r8 <fis-4 \RH #4 >16 (e) \break
    <b \RH #3 >2 f'8\rest <fis-2 \RH #4 >16 (e)
    \bar "|."
  }
}

voiceTwo = \new Voice {
  \voiceTwo
  \set fingeringOrientations    = #'(left)
  \set strokeFingerOrientations = #'(down)
  \set fontSize = #-1   % make note heads smaller

  %\override StrokeFinger.staff-padding = #1.5

  % if there are fingers other than thumbs in voiceTwo, these will be necessary to temporarily set and reset:
  %	\set strokeFingerOrientations = #'(up)
  %	\set strokeFingerOrientations = #'(down)

  \relative c'' {
    a,4 a a8 c\rest
    e,4 b'-2 e,8 c'8\rest
  }
}

voiceFour = \new Voice {     % even numbered voices have the stems down (use \voiceThree instead to have stems up)
  \voiceFour
  \set fingeringOrientations    = #'(left)
  \set strokeFingerOrientations = #'(up)
  \set stringNumberOrientations = #'(down)
  \set fontSize = #-1   % make note heads smaller

  %\override StrokeFinger.staff-padding = #2.5

  \mergeDifferentlyHeadedOn
  \mergeDifferentlyDottedOn
  \override NoteColumn.ignore-collision = ##t

  \relative c'' {
    s2.
    e,16\rest <gis-1 \RH #2 > \set strokeFingerOrientations = #'(down)
    <e-3 \RH #1 > gis b\rest gis e gis f4\rest \set strokeFingerOrientations = #'(up)
  }
}

\score {
  \new Staff <<
    \clef treble
    \key {{ key }} \{{ mode }}
    \tempo 4 = 56-63
    \time 3/4

    % \partial 8

    \voiceOne
    \voiceTwo
    \voiceFour
  >>
}

