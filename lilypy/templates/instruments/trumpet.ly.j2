\layout {
  \context { \Score
    \override MetronomeMark.padding   = #5
    \override MetronomeMark.font-size = #-3
  }
  \context { \Staff
    \override StaffSymbol.thickness   = #0.5
    \override TimeSignature.style     = #'numbered
  }
  \context { \StaffGroup
    \consists "Instrument_name_engraver"
  }
}

TrackAMusicFuncA = #(define-music-function (parser location inTab) (boolean?)
#{
  \relative c' {
    \clef treble
    \key {{ key }} \{{ mode }}
    \tempo "Optional name" 4=144
    \time 4/4

    c4 d e f
  }
#})

TrackAMusicFuncB = #(define-music-function (parser location inTab) (boolean?)
#{
  {% if concert %}
  \transpose b a
  \TrackAMusicFuncA ##f
  {% endif %}
#})

{% if lyrics %}
TrackALyrics = \lyricmode {
  \set ignoreMelismata = ##t
  da doo doo doo
  \unset ignoreMelismata
}
{% endif %}

TrackAStaffA = \new Staff <<
  \context Voice = "TrackAVoiceA" {
    \TrackAMusicFuncA ##f
  }
>>

{% if concert %}
TrackAStaffB = \new Staff <<
  \context Voice = "TrackAVoiceB" {
    \TrackAMusicFuncB ##f
  }
>>
{% endif %}

TrackAStaffGroup = \new StaffGroup <<
  \TrackAStaffA
  {% if lyrics %}
  \new Lyrics = "foo"
  \context Lyrics = "foo" {
    \lyricsto "TrackAVoiceA" {
      \TrackALyrics
    }
  }
  {% endif %}
  {% if concert %}
  \TrackAStaffB
  {% endif %}
>>

\score {
  \TrackAStaffGroup
}

